# Lourex Production Environment Configuration Matrix
# ==================================================
# Instructions:
# - Copy this file to `.env` or inject these variables into your Vercel deployment pipeline.
# - NEVER commit the real `.env` file containing actual tokens to version control.

# --------------------------------------------------
# Core Database & API Platform
# --------------------------------------------------
# Required for the application to function.
VITE_SUPABASE_URL="YOUR_SUPABASE_PROJECT_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Service Role Key for backend administration bypass (Keep this EXTREMELY secret)
# Required ONLY for edge functions or isolated server-side workers.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# --------------------------------------------------
# External Communications Infrastructure
# --------------------------------------------------
# Used for SMS notifications and alerts
TWILIO_ACCOUNT_SID="YOUR_TWILIO_ACCOUNT_SID"
TWILIO_AUTH_TOKEN="YOUR_TWILIO_AUTH_TOKEN"
TWILIO_PHONE_NUMBER="YOUR_TWILIO_PHONE_NUMBER"

# Used for Email notifications, order updates, and support tickets
SENDGRID_API_KEY="YOUR_SENDGRID_API_KEY"
SENDGRID_FROM_EMAIL="YOUR_VERIFIED_SENDER_EMAIL"

# --------------------------------------------------
# Live Market Feed Infrastructure
# --------------------------------------------------
# Dynamic Exchange Rate API provider key for live financial calculations
EXCHANGE_RATE_API_KEY="YOUR_EXCHANGE_RATE_API_KEY"

# --------------------------------------------------
# Platform Security & Cors Configurations
# --------------------------------------------------
ALLOWED_ORIGIN="https://www.lou-rex.com,https://lou-rex.com"
LOVABLE_API_KEY="YOUR_LOVABLE_API_KEY"
